@page "/stats"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = AuthConstants.Manager)]
@{
  var tickets = await TableService.GetAllTicketsAsync();
  var holidays = School.Instance.Holidays ?? [];
  var currentWeekStartUtc = DateTime.UtcNow.Date.AddDays(-(((int)DateTime.UtcNow.DayOfWeek + 6) % 7));
  var threeMonthsAgo = currentWeekStartUtc.AddDays(-13 * 7);
  var sixMonthsAgo = currentWeekStartUtc.AddDays(-26 * 7);
  bool IsHolidayWeek(DateOnly weekStart) => Enumerable.Range(0, 5)
    .Select(offset => weekStart.AddDays(offset))
    .All(day => holidays.Any(h => h.Start <= day && h.End >= day));
  var weeks = tickets
    .Where(o => o.IsClosed && o.LastUpdated >= sixMonthsAgo)
    .GroupBy(o => DateOnly.FromDateTime(o.LastUpdated.Date.AddDays(-(((int)o.LastUpdated.DayOfWeek + 6) % 7))))
    .OrderBy(g => g.Key)
    .Select(g => new
    {
      WeekStart = g.Key,
      IsCurrentWeek = g.Key == DateOnly.FromDateTime(currentWeekStartUtc),
      IsHolidayWeek = IsHolidayWeek(g.Key),
      TicketsClosed = g.Count(),
      AverageTimeToFirstResponse = g.Any(t => t.TimeToFirstResponse is not null)
        ? (int?)g.Where(t => t.TimeToFirstResponse is not null).Median(t => t.TimeToFirstResponse.Value)
        : null
    })
    .ToList();

  var parents = tickets
    .Where(o => o.LastUpdated >= threeMonthsAgo)
    .GroupBy(o => o.ParentEmail)
    .Select(g => new
    {
      ParentName = string.Join(", ", g.GroupBy(o => o.ParentName).OrderByDescending(gg => gg.Count()).ThenBy(gg => gg.Key)
        .Select(gg => gg.Key).Where(o => !string.IsNullOrWhiteSpace(o))),
      StudentName = string.Join(", ", g.GroupBy(o => $"{o.StudentFirstName} {o.StudentLastName}").OrderByDescending(gg => gg.Count()).ThenBy(gg => gg.Key)
        .Select(gg => gg.Key).Where(o => !string.IsNullOrWhiteSpace(o))),
      Count = g.Count()
    })
    .OrderByDescending(o => o.Count)
    .Take(10)
    .ToList();

  var assignees = tickets
    .Where(o => o.LastUpdated >= threeMonthsAgo && o.AssigneeName is not null)
    .GroupBy(o => o.AssigneeName)
    .Select(g => new
    {
      AssigneeName = g.Key,
      Count = g.Count(),
      AverageResponseTime = g.Any(t => t.AverageAssigneeResponseTime is not null)
        ? (int?)g.Where(t => t.AverageAssigneeResponseTime is not null).Average(t => t.AverageAssigneeResponseTime.Value)
        : null
    })
    .Where(o => o.Count >= 3)
    .OrderByDescending(o => o.Count)
    .ToList();
}

<header>
  <div class="header-container">
    <a class="logo-section" href="/tickets/">
      <img src="/img/logo.png" alt="Logo" class="header-logo">
      <h1>Parent Helpdesk</h1>
    </a>
    <div class="user-actions">
      <button class="logout-button" onclick="window.location.href = '/logout'">
        <span class="material-symbols-rounded">logout</span>
        <span>Logout</span>
      </button>
    </div>
  </div>
</header>

<main class="stats-page">

  <section class="stats-panel">
    <div class="stats-panel-heading">
      <h3>Last week</h3>
      <p>All measurements represent time elapsed within working hours 08:30&ndash;16:30.</p>
    </div>

    <div class="stats-headline-grid">
      <article class="stats-headline-card">
        <p class="stats-headline-label">Week beginning</p>
        <p class="stats-headline-value" id="latest-week-range">-</p>
      </article>
      <article class="stats-headline-card">
        <p class="stats-headline-label">Tickets closed</p>
        <p class="stats-headline-value" id="latest-week-count">-</p>
      </article>
      <article class="stats-headline-card">
        <p class="stats-headline-label">Time to first response (median)</p>
        <p class="stats-headline-value" id="latest-week-response">-</p>
      </article>
    </div>
  </section>

  <section class="stats-panel">
    <div class="stats-panel-heading">
      <h3>Trend over time</h3>
      <p>Bars show tickets closed each week. The line shows median time to first response.</p>
    </div>
    <div class="stats-chart-shell">
      <canvas id="weekly-stats-chart"></canvas>
    </div>
  </section>

  <section class="stats-panel">
    <div class="stats-panel-heading">
      <h3>High-volume parents</h3>
      <p>Top ten parents by ticket count from the last three months.</p>
    </div>
    <div class="stats-table-shell">
      <table class="stats-table" id="parents-table">
        <thead>
          <tr>
            <th>
              <button type="button" class="stats-sort-btn" data-table="parents" data-key="parentName" data-type="text">Parent name</button>
            </th>
            <th>
              <button type="button" class="stats-sort-btn" data-table="parents" data-key="studentName" data-type="text">Student name</button>
            </th>
            <th>
              <button type="button" class="stats-sort-btn" data-table="parents" data-key="count" data-type="number" data-default-dir="desc">Tickets created</button>
            </th>
          </tr>
        </thead>
        <tbody id="parents-table-body"></tbody>
      </table>
    </div>
  </section>

  <section class="stats-panel">
    <div class="stats-panel-heading">
      <h3>Top assignees</h3>
      <p>Staff who have been assigned 3+ tickets in the last three months.</p>
    </div>
    <div class="stats-table-shell">
      <table class="stats-table" id="assignees-table">
        <thead>
          <tr>
            <th>
              <button type="button" class="stats-sort-btn" data-table="assignees" data-key="assigneeName" data-type="text">Staff name</button>
            </th>
            <th>
              <button type="button" class="stats-sort-btn" data-table="assignees" data-key="averageResponseTime" data-type="number" data-default-dir="asc">Average response time</button>
            </th>
            <th>
              <button type="button" class="stats-sort-btn" data-table="assignees" data-key="count" data-type="number" data-default-dir="desc">Tickets assigned</button>
            </th>
          </tr>
        </thead>
        <tbody id="assignees-table-body"></tbody>
      </table>
    </div>
  </section>
</main>

<svg style="position: absolute; width: 0; height: 0">
  <defs>
    <filter id="auto-stroke">
      <feMorphology in="SourceAlpha" operator="dilate" radius="1" result="dilated" />
      <feFlood flood-color="white" result="white-fill" />
      <feComposite in="white-fill" in2="dilated" operator="in" result="outline" />
      <feMerge>
        <feMergeNode in="outline" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
</svg>

<script src="/lib/chart.js/dist/chart.umd.min.js"></script>
<script nonce="@HttpContext.Items["csp-nonce"]">
  const weeks = @Html.Raw(Json.Serialize(weeks));
  const parents = @Html.Raw(Json.Serialize(parents));
  const assignees = @Html.Raw(Json.Serialize(assignees));
</script>
<script src="/js/stats.js"></script>
